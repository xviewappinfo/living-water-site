{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "leader": {
      "type": "string"
    },
    "day": {
      "type": "string"
    },
    "time": {
      "type": "string"
    },
    "location": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "openToNewMembers": {
      "default": true,
      "type": "boolean"
    },
    "type": {
      "type": "string",
      "enum": [
        "bible-study",
        "fellowship",
        "prayer",
        "topical"
      ]
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "leader",
    "day",
    "time",
    "location"
  ]
}