---
const quickLinks = [
  { href: '/about', label: 'About Us' },
  { href: '/sermons', label: 'Sermons' },
  { href: '/events', label: 'Events' },
  { href: '/small-groups', label: 'Small Groups' },
  { href: '/youth', label: 'Youth & Young Adults' },
  { href: '/contact', label: 'Contact Us' },
];
---

<footer class="bg-navy-dark text-cream/70">
  <!-- Gold rule top border -->
  <div class="h-px bg-gradient-to-r from-transparent via-gold to-transparent"></div>

  <div class="container mx-auto px-6 py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
      <!-- Brand -->
      <div>
        <div class="flex items-center gap-3 mb-4">
          <span class="text-2xl">💧</span>
          <span class="text-gold font-heading text-lg font-semibold">Living Water</span>
        </div>
        <p class="text-sm leading-relaxed">
          An English-speaking worship community within the Chinese Christian Church of Virginia (CCCVA-SP). Seeking faith, fellowship, and growth together.
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-gold font-heading text-sm font-semibold uppercase tracking-wider mb-4">Explore</h3>
        <ul class="space-y-2">
          {quickLinks.map(link => (
            <li>
              <a href={link.href} class="text-sm hover:text-gold transition-colors duration-200">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact Info -->
      <div>
        <h3 class="text-gold font-heading text-sm font-semibold uppercase tracking-wider mb-4">Connect</h3>
        <div class="space-y-2 text-sm">
          <p>Sunday Worship: 11:00 AM</p>
          <p>CCCVA-SP, Springfield, VA</p>
          <p class="pt-2">
            <a href="mailto:livingwater@cccvasp.org" class="hover:text-gold transition-colors">livingwater@cccvasp.org</a>
          </p>
        </div>
        <div class="mt-4">
          <a href="https://www.cccvasp.org" target="_blank" rel="noopener" class="text-sm hover:text-gold transition-colors">
            CCCVA-SP Main Site &rarr;
          </a>
        </div>
        <!-- Social -->
        <div class="flex gap-4 mt-4">
          <a href="#" aria-label="Facebook" class="text-cream/50 hover:text-gold transition-colors">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <a href="#" aria-label="YouTube" class="text-cream/50 hover:text-gold transition-colors">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
          </a>
          <a href="#" aria-label="Instagram" class="text-cream/50 hover:text-gold transition-colors">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 pt-8 border-t border-cream/10 flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="text-xs text-cream/40">
        &copy; {new Date().getFullYear()} Living Water International Ministry. All rights reserved.
      </p>
      <p class="text-xs text-cream/40">
        A ministry of <a href="https://www.cccvasp.org" target="_blank" rel="noopener" class="hover:text-gold transition-colors">CCCVA-SP</a>
      </p>
    </div>
  </div>
</footer>
