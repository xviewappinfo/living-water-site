---
interface Props {
  title: string;
  subtitle?: string;
  showCta?: boolean;
  compact?: boolean;
}

const { title, subtitle, showCta = false, compact = false } = Astro.props;
---

<section class={`bg-tan relative overflow-hidden ${compact ? 'py-16 md:py-20' : 'py-24 md:py-32'}`}>
  <!-- Subtle diagonal accent -->
  <div class="absolute inset-0 opacity-5">
    <div class="absolute -top-1/2 -right-1/4 w-full h-full bg-coral/20 rotate-12 transform"></div>
  </div>

  <div class="container mx-auto px-6 relative z-10 text-center">
    {/* Accent line above title */}
    <div class="w-16 h-px bg-coral mx-auto mb-8"></div>

    <h1 class="font-heading text-primary-dark text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight max-w-4xl mx-auto">
      {title}
    </h1>

    {subtitle && (
      <p class="mt-6 text-slate text-lg md:text-xl max-w-2xl mx-auto leading-relaxed">
        {subtitle}
      </p>
    )}

    {showCta && (
      <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="btn-primary">Visit Us This Sunday</a>
        <a href="/about" class="btn-outline">Learn More</a>
      </div>
    )}

    {/* Accent line below */}
    <div class="w-16 h-px bg-coral mx-auto mt-10"></div>
  </div>
</section>
