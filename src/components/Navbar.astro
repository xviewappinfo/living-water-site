---
const navLinks = [
  { href: '/about', label: 'About Us' },
  { href: '/sermons', label: 'Sermons' },
  { href: '/events', label: 'Events' },
  { href: '/small-groups', label: 'Small Groups' },
  { href: '/youth', label: 'Youth' },
  { href: '/contact', label: 'Contact' },
];
---

<header class="bg-white/95 backdrop-blur-sm sticky top-0 z-50 border-b border-cream-dark">
  <nav class="container mx-auto px-6 flex items-center justify-between h-20">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-3 shrink-0">
      <span class="text-3xl">💧</span>
      <div>
        <span class="text-coral font-heading text-lg font-semibold tracking-wide">Living Water</span>
        <span class="hidden sm:block text-slate text-xs tracking-wide">International Ministry</span>
      </div>
    </a>

    <!-- Desktop Nav -->
    <div class="hidden lg:flex items-center gap-8">
      {navLinks.map(link => (
        <a href={link.href} class="text-primary-light hover:text-coral text-sm font-medium tracking-wide uppercase transition-colors duration-200">
          {link.label}
        </a>
      ))}
    </div>

    <!-- Mobile Hamburger -->
    <button
      id="mobile-menu-btn"
      class="lg:hidden text-primary p-2"
      aria-label="Open menu"
      aria-expanded="false"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path id="hamburger-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="lg:hidden hidden bg-white border-t border-cream-dark">
    <div class="px-6 py-4 space-y-3">
      {navLinks.map(link => (
        <a href={link.href} class="block text-primary-light hover:text-coral text-sm font-medium tracking-wide uppercase py-2">
          {link.label}
        </a>
      ))}
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    btn.setAttribute('aria-expanded', String(!isOpen));
  });
</script>
