---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import { getEntry, render } from 'astro:content';

const page = await getEntry('pages', 'about');
const { mission, vision, values, team, cccvaspText } = page!.data;
const { Content } = await render(page!);
---

<BaseLayout title="About Us">
  <Hero
    title="About Us"
    subtitle="Learn about our story, mission, and the community we're building together."
    compact={true}
  />

  <!-- Our Story -->
  <section class="section bg-cream">
    <div class="container mx-auto px-6">
      <div class="max-w-3xl mx-auto">
        <h2 class="font-heading text-primary text-3xl md:text-4xl font-bold text-center">How We Began</h2>
        <hr class="gold-rule" />
        <div class="text-slate text-lg leading-relaxed space-y-6 [&>p]:mb-0">
          <Content />
        </div>
      </div>
    </div>
  </section>

  <!-- Mission & Vision -->
  <section class="section bg-white">
    <div class="container mx-auto px-6">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
        <div class="card text-center">
          <div class="text-4xl mb-4">🎯</div>
          <h3 class="font-heading text-primary text-2xl font-semibold mb-4">Our Mission</h3>
          <p class="text-slate leading-relaxed">{mission}</p>
        </div>
        <div class="card text-center">
          <div class="text-4xl mb-4">👁️</div>
          <h3 class="font-heading text-primary text-2xl font-semibold mb-4">Our Vision</h3>
          <p class="text-slate leading-relaxed">{vision}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Core Values -->
  {values && values.length > 0 && (
    <section class="section bg-cream">
      <div class="container mx-auto px-6">
        <div class="text-center mb-12">
          <h2 class="font-heading text-primary text-3xl md:text-4xl font-bold">Core Values</h2>
          <hr class="gold-rule" />
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
          {values.map(v => (
            <div class="card text-center">
              <div class="text-3xl mb-3">{v.icon}</div>
              <h3 class="font-heading text-primary text-lg font-semibold mb-2">{v.title}</h3>
              <p class="text-slate text-sm leading-relaxed">{v.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Pastoral Team -->
  {team && team.length > 0 && (
    <section class="section bg-white">
      <div class="container mx-auto px-6">
        <div class="text-center mb-12">
          <h2 class="font-heading text-primary text-3xl md:text-4xl font-bold">Pastoral Team</h2>
          <hr class="gold-rule" />
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-3xl mx-auto">
          {team.map(member => (
            <div class="card text-center">
              {member.photo ? (
                <img src={member.photo} alt={member.name} class="w-24 h-24 rounded-full mx-auto mb-4 object-cover" />
              ) : (
                <div class="w-24 h-24 bg-coral-light rounded-full mx-auto mb-4 flex items-center justify-center text-4xl">👤</div>
              )}
              <h3 class="font-heading text-primary text-xl font-semibold">{member.name}</h3>
              <p class="text-coral text-sm font-medium mt-1">{member.role}</p>
              <p class="text-slate text-sm leading-relaxed mt-3">{member.bio}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CCCVA-SP Connection -->
  <section class="bg-tan py-16">
    <div class="container mx-auto px-6 text-center">
      <div class="w-16 h-px bg-coral mx-auto mb-8"></div>
      <h2 class="font-heading text-primary-dark text-2xl md:text-3xl font-bold mb-4">Part of CCCVA-SP</h2>
      <p class="text-slate max-w-2xl mx-auto leading-relaxed mb-8">{cccvaspText}</p>
      <a href="https://www.cccvasp.org" target="_blank" rel="noopener" class="btn-outline">Visit CCCVA-SP</a>
      <div class="w-16 h-px bg-coral mx-auto mt-10"></div>
    </div>
  </section>
</BaseLayout>
