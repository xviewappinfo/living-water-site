---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
---

<BaseLayout title="About Us">
  <Hero
    title="About Us"
    subtitle="Learn about our story, mission, and the community we're building together."
    compact={true}
  />

  <!-- Our Story -->
  <section class="section bg-cream">
    <div class="container mx-auto px-6">
      <div class="max-w-3xl mx-auto">
        <h2 class="font-heading text-navy text-3xl md:text-4xl font-bold text-center">How We Began</h2>
        <hr class="gold-rule" />
        <div class="text-slate text-lg leading-relaxed space-y-6">
          <p>
            Living Water International Ministry was born out of a vision to create a vibrant, English-speaking worship community within the Chinese Christian Church of Virginia at Springfield (CCCVA-SP).
          </p>
          <p>
            Recognizing the growing number of English-speaking members — teens, young adults, and families — our church launched this ministry to provide a space where everyone can worship, learn, and grow in their own heart language while remaining connected to the broader CCCVA-SP family.
          </p>
          <p>
            The name "Living Water" comes from Jesus' promise in John 7:38 — that whoever believes in Him will have rivers of living water flowing from within. We believe this promise is for every generation and every culture, and we seek to be a community where that living water flows freely.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Mission & Vision -->
  <section class="section bg-white">
    <div class="container mx-auto px-6">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
        <div class="card text-center">
          <div class="text-4xl mb-4">🎯</div>
          <h3 class="font-heading text-navy text-2xl font-semibold mb-4">Our Mission</h3>
          <p class="text-slate leading-relaxed">
            To nurture a Christ-centered, English-speaking community that worships God, grows in faith, and serves others with love and purpose.
          </p>
        </div>
        <div class="card text-center">
          <div class="text-4xl mb-4">👁️</div>
          <h3 class="font-heading text-navy text-2xl font-semibold mb-4">Our Vision</h3>
          <p class="text-slate leading-relaxed">
            To be a thriving, multigenerational ministry where people of all backgrounds encounter God's living water and are transformed to impact the world.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Core Values -->
  <section class="section bg-cream">
    <div class="container mx-auto px-6">
      <div class="text-center mb-12">
        <h2 class="font-heading text-navy text-3xl md:text-4xl font-bold">Core Values</h2>
        <hr class="gold-rule" />
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        <div class="card text-center">
          <div class="text-3xl mb-3">📖</div>
          <h3 class="font-heading text-navy text-lg font-semibold mb-2">Biblical Foundation</h3>
          <p class="text-slate text-sm leading-relaxed">
            Everything we do is rooted in the truth and authority of God's Word.
          </p>
        </div>
        <div class="card text-center">
          <div class="text-3xl mb-3">❤️</div>
          <h3 class="font-heading text-navy text-lg font-semibold mb-2">Authentic Community</h3>
          <p class="text-slate text-sm leading-relaxed">
            We value real relationships built on honesty, grace, and mutual support.
          </p>
        </div>
        <div class="card text-center">
          <div class="text-3xl mb-3">🌉</div>
          <h3 class="font-heading text-navy text-lg font-semibold mb-2">Cultural Bridge</h3>
          <p class="text-slate text-sm leading-relaxed">
            We honor our heritage while embracing the diverse, English-speaking community we serve.
          </p>
        </div>
        <div class="card text-center">
          <div class="text-3xl mb-3">🌱</div>
          <h3 class="font-heading text-navy text-lg font-semibold mb-2">Next-Gen Leadership</h3>
          <p class="text-slate text-sm leading-relaxed">
            We invest in young people, equipping them to lead and serve in the church and beyond.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Pastoral Team -->
  <section class="section bg-white">
    <div class="container mx-auto px-6">
      <div class="text-center mb-12">
        <h2 class="font-heading text-navy text-3xl md:text-4xl font-bold">Pastoral Team</h2>
        <hr class="gold-rule" />
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-3xl mx-auto">
        <div class="card text-center">
          <div class="w-24 h-24 bg-accent-light rounded-full mx-auto mb-4 flex items-center justify-center text-4xl">👤</div>
          <h3 class="font-heading text-navy text-xl font-semibold">Pastor David Chen</h3>
          <p class="text-gold text-sm font-medium mt-1">Lead Pastor</p>
          <p class="text-slate text-sm leading-relaxed mt-3">
            Pastor David has a heart for bridging generations and cultures through the gospel. He leads our Sunday worship and oversees the ministry's spiritual direction.
          </p>
        </div>
        <div class="card text-center">
          <div class="w-24 h-24 bg-accent-light rounded-full mx-auto mb-4 flex items-center justify-center text-4xl">👤</div>
          <h3 class="font-heading text-navy text-xl font-semibold">Elder James Liu</h3>
          <p class="text-gold text-sm font-medium mt-1">Teaching Elder</p>
          <p class="text-slate text-sm leading-relaxed mt-3">
            Elder James brings years of faithful teaching and mentoring. He leads our prayer ministry and supports small group leaders across the ministry.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CCCVA-SP Connection -->
  <section class="bg-navy-dark py-16">
    <div class="container mx-auto px-6 text-center">
      <div class="w-16 h-px bg-gold mx-auto mb-8"></div>
      <h2 class="font-heading text-cream text-2xl md:text-3xl font-bold mb-4">Part of CCCVA-SP</h2>
      <p class="text-cream/70 max-w-2xl mx-auto leading-relaxed mb-8">
        Living Water is a ministry within the Chinese Christian Church of Virginia at Springfield. We are united in mission with the larger church body while serving the unique needs of our English-speaking community.
      </p>
      <a href="https://www.cccvasp.org" target="_blank" rel="noopener" class="btn-outline">Visit CCCVA-SP</a>
      <div class="w-16 h-px bg-gold mx-auto mt-10"></div>
    </div>
  </section>
</BaseLayout>
