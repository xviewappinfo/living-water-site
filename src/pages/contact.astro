---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
---

<BaseLayout title="Contact & Visit Us">
  <Hero
    title="Contact & Visit Us"
    subtitle="We'd love to hear from you. Come worship with us this Sunday!"
    compact={true}
  />

  <section class="section bg-cream">
    <div class="container mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <!-- Info Column -->
        <div class="space-y-8">
          <div class="card">
            <h3 class="font-heading text-navy text-xl font-semibold mb-3">Service Times</h3>
            <div class="text-slate text-sm space-y-2">
              <p><strong>Sunday Worship:</strong> 11:00 AM</p>
              <p><strong>Sunday School:</strong> 9:30 AM</p>
              <p><strong>Prayer Meeting:</strong> Saturday 8:00 AM</p>
            </div>
          </div>

          <div class="card">
            <h3 class="font-heading text-navy text-xl font-semibold mb-3">Location</h3>
            <div class="text-slate text-sm space-y-2">
              <p>Chinese Christian Church of Virginia — Springfield</p>
              <p>CCCVA-SP, Springfield, VA</p>
            </div>
          </div>

          <div class="card">
            <h3 class="font-heading text-navy text-xl font-semibold mb-3">Get in Touch</h3>
            <div class="text-slate text-sm space-y-2">
              <p>
                <a href="mailto:livingwater@cccvasp.org" class="text-accent hover:text-navy transition-colors">livingwater@cccvasp.org</a>
              </p>
            </div>
          </div>

          <div class="card">
            <h3 class="font-heading text-navy text-xl font-semibold mb-3">What to Expect</h3>
            <div class="text-slate text-sm leading-relaxed space-y-2">
              <p>Come as you are! Our services include contemporary worship music, Bible-based teaching, and warm fellowship.</p>
              <p>Visitors are always welcome. You'll find a friendly community ready to connect with you.</p>
            </div>
          </div>
        </div>

        <!-- Form & Map Column -->
        <div class="space-y-8">
          <div class="card">
            <h3 class="font-heading text-navy text-xl font-semibold mb-6">Send Us a Message</h3>
            <form name="contact" method="POST" data-netlify="true" class="space-y-4">
              <input type="hidden" name="form-name" value="contact" />
              <div>
                <label for="name" class="block text-sm font-medium text-navy mb-1">Name</label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  class="w-full border border-cream-dark rounded px-4 py-2.5 text-sm focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent bg-white"
                  placeholder="Your name"
                />
              </div>
              <div>
                <label for="email" class="block text-sm font-medium text-navy mb-1">Email</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  class="w-full border border-cream-dark rounded px-4 py-2.5 text-sm focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent bg-white"
                  placeholder="your@email.com"
                />
              </div>
              <div>
                <label for="message" class="block text-sm font-medium text-navy mb-1">Message</label>
                <textarea
                  id="message"
                  name="message"
                  rows="5"
                  required
                  class="w-full border border-cream-dark rounded px-4 py-2.5 text-sm focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent bg-white resize-vertical"
                  placeholder="How can we help?"
                ></textarea>
              </div>
              <button type="submit" class="btn-primary w-full text-center">Send Message</button>
            </form>
          </div>

          <!-- Map -->
          <div class="card !p-0 overflow-hidden">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3114.123!2d-77.18!3d38.78!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMzjCsDQ2JzQ4LjAiTiA3N8KwMTAnNDguMCJX!5e0!3m2!1sen!2sus!4v1234567890"
              width="100%"
              height="300"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="Church location"
            ></iframe>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
