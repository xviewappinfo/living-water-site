---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import { getEntry, render } from 'astro:content';

const page = await getEntry('pages', 'contact');
const { serviceTimes, location, address, email, mapEmbedUrl } = page!.data;
const { Content } = await render(page!);
---

<BaseLayout title="Contact & Visit Us">
  <Hero
    title="Contact & Visit Us"
    subtitle="We'd love to hear from you. Come worship with us this Sunday!"
    compact={true}
  />

  <section class="section bg-cream">
    <div class="container mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <!-- Info Column -->
        <div class="space-y-8">
          {serviceTimes && serviceTimes.length > 0 && (
            <div class="card">
              <h3 class="font-heading text-primary text-xl font-semibold mb-3">Service Times</h3>
              <div class="text-slate text-sm space-y-2">
                {serviceTimes.map(s => (
                  <p><strong>{s.label}:</strong> {s.time}</p>
                ))}
              </div>
            </div>
          )}

          {location && (
            <div class="card">
              <h3 class="font-heading text-primary text-xl font-semibold mb-3">Location</h3>
              <div class="text-slate text-sm space-y-2">
                <p>{location}</p>
                {address && <p>{address}</p>}
              </div>
            </div>
          )}

          {email && (
            <div class="card">
              <h3 class="font-heading text-primary text-xl font-semibold mb-3">Get in Touch</h3>
              <div class="text-slate text-sm space-y-2">
                <p>
                  <a href={`mailto:${email}`} class="text-coral hover:text-primary transition-colors">{email}</a>
                </p>
              </div>
            </div>
          )}

          <div class="card">
            <h3 class="font-heading text-primary text-xl font-semibold mb-3">What to Expect</h3>
            <div class="text-slate text-sm leading-relaxed space-y-2">
              <Content />
            </div>
          </div>
        </div>

        <!-- Form & Map Column -->
        <div class="space-y-8">
          <div class="card">
            <h3 class="font-heading text-primary text-xl font-semibold mb-6">Send Us a Message</h3>
            <form name="contact" method="POST" data-netlify="true" class="space-y-4">
              <input type="hidden" name="form-name" value="contact" />
              <div>
                <label for="name" class="block text-sm font-medium text-primary mb-1">Name</label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  class="w-full border border-cream-dark rounded px-4 py-2.5 text-sm focus:outline-none focus:border-coral focus:ring-1 focus:ring-coral bg-white"
                  placeholder="Your name"
                />
              </div>
              <div>
                <label for="email" class="block text-sm font-medium text-primary mb-1">Email</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  class="w-full border border-cream-dark rounded px-4 py-2.5 text-sm focus:outline-none focus:border-coral focus:ring-1 focus:ring-coral bg-white"
                  placeholder="your@email.com"
                />
              </div>
              <div>
                <label for="message" class="block text-sm font-medium text-primary mb-1">Message</label>
                <textarea
                  id="message"
                  name="message"
                  rows="5"
                  required
                  class="w-full border border-cream-dark rounded px-4 py-2.5 text-sm focus:outline-none focus:border-coral focus:ring-1 focus:ring-coral bg-white resize-vertical"
                  placeholder="How can we help?"
                ></textarea>
              </div>
              <button type="submit" class="btn-primary w-full text-center">Send Message</button>
            </form>
          </div>

          <!-- Map -->
          {mapEmbedUrl && (
            <div class="card !p-0 overflow-hidden">
              <iframe
                src={mapEmbedUrl}
                width="100%"
                height="300"
                style="border:0;"
                allowfullscreen=""
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
                title="Church location"
              ></iframe>
            </div>
          )}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
