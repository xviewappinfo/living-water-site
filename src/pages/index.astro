---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import { getCollection } from 'astro:content';

const allEvents = await getCollection('events');
const allSermons = await getCollection('sermons');

const now = new Date();
const upcomingEvents = allEvents
  .filter(e => new Date(e.data.date) >= now)
  .sort((a, b) => new Date(a.data.date).getTime() - new Date(b.data.date).getTime())
  .slice(0, 3);

const recentSermons = allSermons
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);
---

<BaseLayout title="Home">
  <Hero
    title="Come, All Who Are Thirsty"
    subtitle="Living Water International Ministry — an English-speaking worship community within CCCVA-SP, seeking faith, fellowship, and growth together."
    showCta={true}
  />

  <!-- Welcome Section -->
  <section class="section bg-cream">
    <div class="container mx-auto px-6">
      <div class="text-center mb-12">
        <h2 class="font-heading text-navy text-3xl md:text-4xl font-bold">Welcome to Living Water</h2>
        <hr class="gold-rule" />
        <p class="text-slate max-w-2xl mx-auto text-lg leading-relaxed">
          Whether you're exploring faith for the first time or deepening your walk with God, there's a place for you here.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="card text-center">
          <div class="text-4xl mb-4">🙏</div>
          <h3 class="font-heading text-navy text-xl font-semibold mb-2">Worship</h3>
          <p class="text-slate text-sm leading-relaxed">
            Join us every Sunday at 11:00 AM for worship, prayer, and teaching rooted in God's Word.
          </p>
        </div>
        <div class="card text-center">
          <div class="text-4xl mb-4">🤝</div>
          <h3 class="font-heading text-navy text-xl font-semibold mb-2">Small Groups</h3>
          <p class="text-slate text-sm leading-relaxed">
            Connect with others through Bible studies, fellowship groups, and prayer meetings throughout the week.
          </p>
        </div>
        <div class="card text-center">
          <div class="text-4xl mb-4">🌊</div>
          <h3 class="font-heading text-navy text-xl font-semibold mb-2">Community & Service</h3>
          <p class="text-slate text-sm leading-relaxed">
            We serve together, grow together, and build authentic relationships that reflect Christ's love.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Upcoming Events -->
  {upcomingEvents.length > 0 && (
    <section class="section bg-white">
      <div class="container mx-auto px-6">
        <div class="text-center mb-12">
          <h2 class="font-heading text-navy text-3xl md:text-4xl font-bold">Upcoming Events</h2>
          <hr class="gold-rule" />
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {upcomingEvents.map(event => {
            const eventDate = new Date(event.data.date);
            return (
              <div class="card">
                {event.data.featured && (
                  <span class="inline-block bg-gold/20 text-gold-dark text-xs font-semibold uppercase tracking-wider px-3 py-1 rounded mb-4">Featured</span>
                )}
                <h3 class="font-heading text-navy text-xl font-semibold mb-2">{event.data.title}</h3>
                <div class="text-slate text-sm space-y-1 mb-3">
                  <p>{eventDate.toLocaleDateString('en-US', { weekday: 'long', month: 'long', day: 'numeric', year: 'numeric' })}</p>
                  {event.data.time && <p>{event.data.time}</p>}
                  {event.data.location && <p>{event.data.location}</p>}
                </div>
                {event.data.description && (
                  <p class="text-slate text-sm leading-relaxed">{event.data.description}</p>
                )}
              </div>
            );
          })}
        </div>

        <div class="text-center mt-10">
          <a href="/events" class="btn-primary">View All Events</a>
        </div>
      </div>
    </section>
  )}

  <!-- Recent Sermons -->
  {recentSermons.length > 0 && (
    <section class="section bg-cream">
      <div class="container mx-auto px-6">
        <div class="text-center mb-12">
          <h2 class="font-heading text-navy text-3xl md:text-4xl font-bold">Recent Sermons</h2>
          <hr class="gold-rule" />
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {recentSermons.map(sermon => (
            <div class="card">
              <div class="text-xs text-slate uppercase tracking-wider mb-2">
                {new Date(sermon.data.date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
              </div>
              <h3 class="font-heading text-navy text-xl font-semibold mb-1">{sermon.data.title}</h3>
              <p class="text-accent text-sm font-medium mb-2">{sermon.data.speaker}</p>
              {sermon.data.scripture && (
                <p class="text-slate text-sm italic mb-3">{sermon.data.scripture}</p>
              )}
              {sermon.data.description && (
                <p class="text-slate text-sm leading-relaxed">{sermon.data.description}</p>
              )}
              <div class="flex gap-3 mt-4">
                {sermon.data.audioUrl && (
                  <a href={sermon.data.audioUrl} class="text-accent text-sm font-medium hover:text-navy transition-colors">Listen</a>
                )}
                {sermon.data.videoUrl && (
                  <a href={sermon.data.videoUrl} class="text-accent text-sm font-medium hover:text-navy transition-colors">Watch</a>
                )}
              </div>
            </div>
          ))}
        </div>

        <div class="text-center mt-10">
          <a href="/sermons" class="btn-primary">All Sermons</a>
        </div>
      </div>
    </section>
  )}

  <!-- Scripture CTA -->
  <section class="bg-navy-dark py-20">
    <div class="container mx-auto px-6 text-center">
      <div class="w-16 h-px bg-gold mx-auto mb-8"></div>
      <blockquote class="font-heading text-cream text-2xl md:text-3xl italic max-w-3xl mx-auto leading-relaxed">
        "Whoever believes in me, as Scripture has said, rivers of living water will flow from within them."
      </blockquote>
      <p class="text-gold mt-6 font-medium">— John 7:38 (NIV)</p>
      <div class="w-16 h-px bg-gold mx-auto mt-8"></div>
    </div>
  </section>
</BaseLayout>
