---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import { getCollection, getEntry } from 'astro:content';

const page = await getEntry('pages', 'home');
const { heroTitle, heroSubtitle, welcomeHeading, welcomeText, cards, scriptureQuote, scriptureRef } = page!.data;

const allEvents = await getCollection('events');
const allSermons = await getCollection('sermons');

const now = new Date();
const upcomingEvents = allEvents
  .filter(e => new Date(e.data.date) >= now)
  .sort((a, b) => new Date(a.data.date).getTime() - new Date(b.data.date).getTime())
  .slice(0, 3);

const recentSermons = allSermons
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);
---

<BaseLayout title="Home">
  <Hero
    title={heroTitle || "Come, All Who Are Thirsty"}
    subtitle={heroSubtitle}
    showCta={true}
  />

  <!-- Welcome Section -->
  <section class="section bg-cream">
    <div class="container mx-auto px-6">
      <div class="text-center mb-12">
        <h2 class="font-heading text-primary text-3xl md:text-4xl font-bold">{welcomeHeading}</h2>
        <hr class="gold-rule" />
        <p class="text-slate max-w-2xl mx-auto text-lg leading-relaxed">{welcomeText}</p>
      </div>

      {cards && cards.length > 0 && (
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {cards.map(card => (
            <div class="card text-center">
              <div class="text-4xl mb-4">{card.icon}</div>
              <h3 class="font-heading text-primary text-xl font-semibold mb-2">{card.title}</h3>
              <p class="text-slate text-sm leading-relaxed">{card.description}</p>
            </div>
          ))}
        </div>
      )}
    </div>
  </section>

  <!-- Upcoming Events -->
  {upcomingEvents.length > 0 && (
    <section class="section bg-white">
      <div class="container mx-auto px-6">
        <div class="text-center mb-12">
          <h2 class="font-heading text-primary text-3xl md:text-4xl font-bold">Upcoming Events</h2>
          <hr class="gold-rule" />
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {upcomingEvents.map(event => {
            const eventDate = new Date(event.data.date);
            return (
              <div class="card">
                {event.data.featured && (
                  <span class="inline-block bg-coral/15 text-coral-dark text-xs font-semibold uppercase tracking-wider px-3 py-1 rounded mb-4">Featured</span>
                )}
                <h3 class="font-heading text-primary text-xl font-semibold mb-2">{event.data.title}</h3>
                <div class="text-slate text-sm space-y-1 mb-3">
                  <p>{eventDate.toLocaleDateString('en-US', { weekday: 'long', month: 'long', day: 'numeric', year: 'numeric' })}</p>
                  {event.data.time && <p>{event.data.time}</p>}
                  {event.data.location && <p>{event.data.location}</p>}
                </div>
                {event.data.description && (
                  <p class="text-slate text-sm leading-relaxed">{event.data.description}</p>
                )}
              </div>
            );
          })}
        </div>

        <div class="text-center mt-10">
          <a href="/events" class="btn-primary">View All Events</a>
        </div>
      </div>
    </section>
  )}

  <!-- Recent Sermons -->
  {recentSermons.length > 0 && (
    <section class="section bg-cream">
      <div class="container mx-auto px-6">
        <div class="text-center mb-12">
          <h2 class="font-heading text-primary text-3xl md:text-4xl font-bold">Recent Sermons</h2>
          <hr class="gold-rule" />
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {recentSermons.map(sermon => (
            <div class="card">
              <div class="text-xs text-slate uppercase tracking-wider mb-2">
                {new Date(sermon.data.date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
              </div>
              <h3 class="font-heading text-primary text-xl font-semibold mb-1">{sermon.data.title}</h3>
              <p class="text-coral text-sm font-medium mb-2">{sermon.data.speaker}</p>
              {sermon.data.scripture && (
                <p class="text-slate text-sm italic mb-3">{sermon.data.scripture}</p>
              )}
              {sermon.data.description && (
                <p class="text-slate text-sm leading-relaxed">{sermon.data.description}</p>
              )}
              <div class="flex gap-3 mt-4">
                {sermon.data.audioUrl && (
                  <a href={sermon.data.audioUrl} class="text-coral text-sm font-medium hover:text-primary transition-colors">Listen</a>
                )}
                {sermon.data.videoUrl && (
                  <a href={sermon.data.videoUrl} class="text-coral text-sm font-medium hover:text-primary transition-colors">Watch</a>
                )}
              </div>
            </div>
          ))}
        </div>

        <div class="text-center mt-10">
          <a href="/sermons" class="btn-primary">All Sermons</a>
        </div>
      </div>
    </section>
  )}

  <!-- Scripture CTA -->
  <section class="bg-tan py-20">
    <div class="container mx-auto px-6 text-center">
      <div class="w-16 h-px bg-coral mx-auto mb-8"></div>
      <blockquote class="font-heading text-primary-dark text-2xl md:text-3xl italic max-w-3xl mx-auto leading-relaxed">
        "{scriptureQuote}"
      </blockquote>
      <p class="text-coral mt-6 font-medium">{scriptureRef}</p>
      <div class="w-16 h-px bg-coral mx-auto mt-8"></div>
    </div>
  </section>
</BaseLayout>
