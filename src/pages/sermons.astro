---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import { getCollection } from 'astro:content';

const allSermons = await getCollection('sermons');
const sermons = allSermons.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<BaseLayout title="Worship & Sermons">
  <Hero
    title="Worship & Sermons"
    subtitle="Listen to recent messages and be encouraged in your faith journey."
    compact={true}
  />

  <section class="section bg-cream">
    <div class="container mx-auto px-6">
      {sermons.length > 0 ? (
        <div class="max-w-3xl mx-auto space-y-6">
          {sermons.map(sermon => {
            const date = new Date(sermon.data.date);
            const month = date.toLocaleDateString('en-US', { month: 'short' }).toUpperCase();
            const day = date.getDate();
            return (
              <div class="card flex flex-col sm:flex-row gap-6">
                {/* Date Badge */}
                <div class="shrink-0 text-center">
                  <div class="w-16 h-16 bg-navy rounded flex flex-col items-center justify-center">
                    <span class="text-gold text-xs font-semibold uppercase tracking-wider">{month}</span>
                    <span class="text-cream text-xl font-bold leading-tight">{day}</span>
                  </div>
                </div>

                {/* Sermon Info */}
                <div class="flex-1">
                  <h3 class="font-heading text-navy text-xl font-semibold">{sermon.data.title}</h3>
                  <p class="text-accent text-sm font-medium mt-1">{sermon.data.speaker}</p>
                  {sermon.data.scripture && (
                    <p class="text-slate text-sm italic mt-1">{sermon.data.scripture}</p>
                  )}
                  {sermon.data.series && (
                    <span class="inline-block bg-gold/15 text-gold-dark text-xs font-semibold uppercase tracking-wider px-2 py-0.5 rounded mt-2">
                      {sermon.data.series}
                    </span>
                  )}
                  {sermon.data.description && (
                    <p class="text-slate text-sm leading-relaxed mt-3">{sermon.data.description}</p>
                  )}
                  <div class="flex gap-4 mt-4">
                    {sermon.data.audioUrl && (
                      <a href={sermon.data.audioUrl} class="btn-primary text-xs !py-2 !px-4">Listen</a>
                    )}
                    {sermon.data.videoUrl && (
                      <a href={sermon.data.videoUrl} class="btn-outline text-xs !py-2 !px-4 !text-navy !border-navy hover:!bg-navy hover:!text-gold">Watch</a>
                    )}
                  </div>
                </div>
              </div>
            );
          })}
        </div>
      ) : (
        <div class="text-center text-slate text-lg">
          <p>No sermons available yet. Check back soon!</p>
        </div>
      )}
    </div>
  </section>
</BaseLayout>
