---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import { getEntry, render } from 'astro:content';

const page = await getEntry('pages', 'youth');
const { programs, volunteerOpps, parentCtaText } = page!.data;
const { Content } = await render(page!);
---

<BaseLayout title="Youth & Young Adults">
  <Hero
    title="Youth & Young Adults"
    subtitle="A vibrant community for ages 13+ where faith meets real life."
    compact={true}
  />

  <!-- Overview -->
  <section class="section bg-cream">
    <div class="container mx-auto px-6">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="font-heading text-primary text-3xl md:text-4xl font-bold">Growing Together</h2>
        <hr class="gold-rule" />
        <div class="text-slate text-lg leading-relaxed">
          <Content />
        </div>
      </div>
    </div>
  </section>

  <!-- Programs -->
  {programs && programs.length > 0 && (
    <section class="section bg-white">
      <div class="container mx-auto px-6">
        <div class="text-center mb-12">
          <h2 class="font-heading text-primary text-3xl md:text-4xl font-bold">Programs</h2>
          <hr class="gold-rule" />
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {programs.map(p => (
            <div class="card text-center">
              <div class="text-4xl mb-4">{p.icon}</div>
              <h3 class="font-heading text-primary text-lg font-semibold mb-2">{p.title}</h3>
              <p class="text-slate text-sm leading-relaxed">{p.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Volunteer Opportunities -->
  {volunteerOpps && volunteerOpps.length > 0 && (
    <section class="section bg-cream">
      <div class="container mx-auto px-6">
        <div class="text-center mb-12">
          <h2 class="font-heading text-primary text-3xl md:text-4xl font-bold">Get Involved</h2>
          <hr class="gold-rule" />
          <p class="text-slate text-lg max-w-2xl mx-auto leading-relaxed">
            There are many ways to serve and use your gifts. Here are some current opportunities:
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
          {volunteerOpps.map(v => (
            <div class="card text-center">
              <div class="text-3xl mb-3">{v.icon}</div>
              <h3 class="font-heading text-primary text-lg font-semibold mb-2">{v.title}</h3>
              <p class="text-slate text-sm leading-relaxed">{v.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Parent CTA -->
  <section class="bg-tan py-16">
    <div class="container mx-auto px-6 text-center">
      <div class="w-16 h-px bg-coral mx-auto mb-8"></div>
      <h2 class="font-heading text-primary-dark text-2xl md:text-3xl font-bold mb-4">Parents & Guardians</h2>
      <p class="text-slate max-w-2xl mx-auto leading-relaxed mb-8">{parentCtaText}</p>
      <a href="/contact" class="btn-primary">Get in Touch</a>
      <div class="w-16 h-px bg-coral mx-auto mt-10"></div>
    </div>
  </section>
</BaseLayout>
